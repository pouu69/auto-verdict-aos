<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow ring -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="oval">
            <solid android:color="#1A0050FF" />
        </shape>
    </item>
    <!-- Main circle with gradient -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#0064FF"
                android:centerColor="#0055E0"
                android:endColor="#003DB8"
                android:type="linear" />
        </shape>
    </item>
    <!-- Inner highlight (top-left light reflection) -->
    <item
        android:bottom="18dp"
        android:left="6dp"
        android:right="18dp"
        android:top="6dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
